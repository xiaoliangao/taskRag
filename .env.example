APP_ENV=development
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# ----- Database / Cache / Vector -----
DATABASE_URL=postgresql+asyncpg://taskrag:taskrag@postgres:5432/taskrag
SYNC_DATABASE_URL=postgresql+psycopg://taskrag:taskrag@postgres:5432/taskrag
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

# ----- JWT -----
JWT_SECRET_KEY=change-me-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- Storage -----
PDF_STORAGE_DIR=/data/pdfs
FULLTEXT_STORAGE_DIR=/data/fulltext
UPLOAD_STORAGE_DIR=/data/uploads

# ----- Embedding (SiliconFlow OpenAI-compatible) -----
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
SILICONFLOW_API_KEY=

# ----- Reranker (SiliconFlow rerank API; reuses SILICONFLOW_API_KEY) -----
RERANKER_ENABLED=true
RERANKER_BASE_URL=https://api.siliconflow.cn/v1
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ----- LLM (OpenAI-compatible) -----
# provider: deepseek | qwen | siliconflow | openai
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# SiliconFlow can also serve as LLM (e.g. Qwen2.5 hosted there)
SILICONFLOW_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ----- Email (Gmail SMTP) -----
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
EMAIL_FROM=

# ----- Source API keys (optional) -----
GITHUB_TOKEN=
SEMANTIC_SCHOLAR_API_KEY=

# ----- Demo seed -----
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=demo123

# ----- Frontend -----
VITE_API_BASE_URL=http://localhost:8000
